# App
PROJECT_NAME="APEX Housing"
VERSION="1.0.0"
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-in-production
DATABASE_URL=postgresql+asyncpg://apex:apex_password@localhost:5432/apex_housing
REDIS_URL=redis://localhost:6379/0

# CORS (add production domain when deploying)
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:8099","http://127.0.0.1:5173","http://127.0.0.1:5174","https://apex-housing-api.onrender.com"]

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Paystack (Payment Gateway)
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=whsec_xxx

# Paystack fees
PAYSTACK_FEE_PERCENT=1.5
PAYSTACK_FEE_CAP=2000.0

# Platform ID (embedded in every Paystack reference to distinguish this platform)
PAYSTACK_PLATFORM_ID=APXHOUSING

# Supabase (Storage)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
SUPABASE_STORAGE_BUCKET=apex-media

# Firebase (Push Notifications)
# For local dev: use FIREBASE_CREDENTIALS_PATH pointing to the JSON file
# For Render/cloud: paste the full JSON content into FIREBASE_CREDENTIALS_JSON
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json
FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=apex-housing-xxx

# Email (Resend with multi-key rotation)
SMTP_FROM_EMAIL=noreply@onresend.com
SMTP_FROM_NAME=APEX Housing
RESEND_API_KEYS=re_key1,re_key2,re_key3
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Google Maps (Geocoding)
GOOGLE_MAPS_API_KEY=AIzaSyxxx

# Sentry (Error Tracking)
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_TRACES_SAMPLE_RATE=0.1

# Google OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://apex-housing-api.onrender.com/api/v1/auth/google/callback

# App Settings
FRONTEND_URL=https://apex-housing-api.onrender.com
USE_SSL=true
RATE_LIMIT_ENABLED=true
LOG_LEVEL=INFO
LOG_REQUEST_BODY=false
MAX_UPLOAD_SIZE_MB=10

# Support Email (user-facing)
SUPPORT_EMAIL=support@apex-housing.online
